---
import { base } from 'astro:config';
---
<section class="min-h-screen flex items-center justify-center">
	<div class="text-center">
		<h1 class="m-0 mb-4 text-3xl text-neutral-900 dark:text-neutral-100">Phúc học Phật</h1>
		<div class="flex items-center justify-center gap-3">
			<a href={`${base}con-duong`} class="inline-block px-4 py-2 border border-neutral-300 rounded text-neutral-900 no-underline hover:bg-neutral-100 dark:border-neutral-300/40 dark:text-neutral-100 dark:hover:bg-neutral-800">Bắt đầu</a>
			<a href={`${base}thu-vien`} class="inline-block px-4 py-2 border border-neutral-300 rounded text-neutral-900 no-underline hover:bg-neutral-100 dark:border-neutral-300/40 dark:text-neutral-100 dark:hover:bg-neutral-800">Khám phá</a>
		</div>
	</div>
</section>
