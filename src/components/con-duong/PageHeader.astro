---
const { title, description } = Astro.props as {
  title: string;
  description?: string;
};
---

<header class="mx-auto max-w-3xl px-4 py-8">
  <h1 class="text-3xl font-semibold">{title}</h1>
  {description && (
    <p class="mt-2 text-sm opacity-80">{description}</p>
  )}
  <div class="mt-4 h-px w-full bg-neutral-200/70 dark:bg-neutral-800/70"></div>
  <slot />
</header>


