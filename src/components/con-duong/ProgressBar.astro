---
const { value, max } = Astro.props as { value: number; max: number };
const pct = Math.max(0, Math.min(100, Math.round((value / Math.max(1, max)) * 100)));
---

<div class="w-full">
  <div class="flex items-center justify-between text-xs mb-1">
    <span>Tiến độ</span>
    <span>{pct}%</span>
  </div>
  <div class="h-2 rounded bg-neutral-200/70 dark:bg-neutral-800/70 overflow-hidden">
    <div class="h-full bg-neutral-800 dark:bg-neutral-100" style={`width: ${pct}%`}></div>
  </div>
  <slot />
</div>


