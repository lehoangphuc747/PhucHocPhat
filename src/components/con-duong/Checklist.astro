---
interface ChecklistItem {
  label: string;
  note?: string;
}

const { items } = Astro.props as { items: ChecklistItem[] };
---

<ul class="space-y-2">
  {items.map((item) => (
    <li class="flex items-start gap-2">
      <input type="checkbox" class="mt-1" aria-label={item.label} />
      <div>
        <div>{item.label}</div>
        {item.note && <div class="text-xs opacity-70">{item.note}</div>}
      </div>
    </li>
  ))}
  <slot />
</ul>


